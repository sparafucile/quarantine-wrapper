{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    ":semanticCommits"
  ],
  "packageRules": [
    {
      "description": "Container-Images in values.yaml",
      "matchManagers": ["regex"],
      "matchFileNames": ["values.yaml"],
      "automerge": false,
      "groupName": "container-images"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["values\\.yaml$"],
      "matchStrings": [
        "repository:\\s*(?<depName>[\\w./-]+)\\n\\s*tag:\\s*[\"']?(?<currentValue>[\\w.-]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
